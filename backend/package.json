{
  "name": "stockmaster-backend",
  "version": "1.0.0",
  "description": "Backend API for StockMaster Pro",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "typeorm": "ts-node ./node_modules/typeorm/cli",
    "migration:run": "ts-node ./node_modules/typeorm/cli migration:run -d ormconfig.ts",
    "migration:revert": "ts-node ./node_modules/typeorm/cli migration:revert -d ormconfig.ts",
    "migration:generate": "ts-node ./node_modules/typeorm/cli migration:generate -d ormconfig.ts",
    "init-db": "ts-node src/scripts/init-database.ts",
    "verify-data": "ts-node src/scripts/verify-data.ts",
    "test-api": "ts-node src/scripts/test-api.ts",
    "create-unit-conversions": "ts-node src/scripts/create-unit-conversions-table.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/multer": "^2.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "mysql2": "^3.6.5",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
